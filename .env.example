# Mock offline (tùy chọn): =true để FE đọc dữ liệu thật từ /public/mock
# (trích từ bản dump PostgreSQL bằng `scripts/gen-mock-data.sh`), KHÔNG cần
# chạy air-quality-api / air-quality-be. Để trống/false = dùng backend thật.
VITE_USE_MOCK=false

VITE_AIR_QUALITY_API_URL=http://localhost:3002/api/v1
VITE_AIR_QUALITY_BE_URL=http://localhost:8000/api/v1
VITE_AIR_QUALITY_ADMIN_URL=http://localhost:5174

# Web Push — paste VAPID_PUBLIC_KEY từ air-quality-api/.env vào đây.
# Tạo cặp khóa: `npx web-push generate-vapid-keys` (chạy ở backend).
VITE_VAPID_PUBLIC_KEY=

# Đăng nhập Google (tùy chọn). Để trống = ẩn nút "Đăng nhập bằng Google".
# Lấy OAuth 2.0 Client ID (Web) tại https://console.cloud.google.com
# Phải khớp GOOGLE_CLIENT_ID ở air-quality-api/.env
VITE_GOOGLE_CLIENT_ID=
